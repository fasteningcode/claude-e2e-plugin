# ─────────────────────────────────────────────
# ClaudeTest — environment variables reference
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── MCP Server ────────────────────────────────

# GitHub personal access token (fallback for stdio/self-hosted mode)
# For Claude.ai remote mode this is injected per-request via OAuth — not needed here
# Generate at: https://github.com/settings/tokens (scopes: repo, workflow)
GITHUB_TOKEN=ghp_your_token_here

# HTTP server port (default: 3000 | Hugging Face Spaces requires: 7860)
PORT=3000

# Transport mode: leave unset for HTTP, set to "stdio" for Claude Code local mode
# MCP_TRANSPORT=stdio

# ── Appium (mobile test generation) ───────────

# Target platform for generated Appium tests (default: Android)
PLATFORM=Android

# Path to your compiled .app (iOS) or .apk (Android)
APP_PATH=/path/to/your/app.apk

# Appium server connection (default: localhost:4723)
APPIUM_HOST=localhost
APPIUM_PORT=4723

# iOS device config (used when PLATFORM=iOS)
IOS_DEVICE=iPhone 15
IOS_VERSION=17.0

# Android device config (used when PLATFORM=Android)
ANDROID_DEVICE=emulator-5554

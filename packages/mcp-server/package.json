{
  "name": "@claudetest/mcp-server",
  "version": "0.0.1",
  "description": "MCP server plugin for enterprise Playwright & Appium testing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "claudetest": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "tsc -p tsconfig.json --watch"
  },
  "dependencies": {
    "@claudetest/playwright-agent": "workspace:*",
    "@claudetest/appium-agent": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@octokit/rest": "^20.1.1",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0"
  },
  "files": ["dist"],
  "keywords": ["claude", "mcp", "testing", "playwright", "appium", "enterprise"]
}
